{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/server.js" },
    { "src": "/admin/login", "dest": "/server.js" },
    { "src": "/admin/dashboard", "dest": "/server.js" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
